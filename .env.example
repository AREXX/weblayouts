# Copy these into Vercel → Project → Settings → Environment Variables.
# (Do NOT commit real values. This file only documents the names.)

# --- Google Calendar (the appointment book / source of truth) ---
# From the service-account JSON key you download from Google Cloud:
GOOGLE_CLIENT_EMAIL=booking-bot@your-project.iam.gserviceaccount.com
# Paste the private_key value exactly, including the \n sequences, in quotes:
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# The calendar you shared with the service account (its ID, or "primary"
# if the bot owns the calendar). Find it in Google Calendar → Settings → your
# calendar → "Integrate calendar" → Calendar ID.
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
# Shop timezone (defaults to America/Chicago if unset).
SHOP_TZ=America/Chicago

# --- Email notification to Rese (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Where the "new booking" email is sent:
BOOKING_EMAIL_TO=rese@example.com
# The "from" address. Until you verify a domain in Resend you can leave the
# default (onboarding@resend.dev). After verifying, use e.g.
# "Premium Quality Cuts <bookings@yourdomain.com>".
BOOKING_EMAIL_FROM=Premium Quality Cuts <onboarding@resend.dev>
